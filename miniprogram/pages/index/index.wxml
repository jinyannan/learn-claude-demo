<view class="container">
  <view class="header">
    <text class="title">PetConnect 社区</text>
  </view>

  <view class="pet-list">
    <block wx:if="{{pets.length > 0}}">
      <view class="pet-card" wx:for="{{pets}}" wx:key="id">
        <image class="pet-image" src="{{item.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
        <view class="pet-info">
          <text class="pet-name">{{item.name}}</text>
          <text class="pet-breed">{{item.breed}}</text>
        </view>
      </view>
    </block>
    <view wx:else class="empty-state">
      <text>暂无宠物，快去添加吧！</text>
    </view>
  </view>
</view>
