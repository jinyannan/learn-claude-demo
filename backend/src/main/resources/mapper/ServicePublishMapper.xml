<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.learnclaudedemo.mapper.ServicePublishMapper">
    <resultMap id="BaseResultMap" type="com.example.learnclaudedemo.entity.ServicePublish">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="service_type_id" property="serviceTypeId"/>
        <result column="title" property="title"/>
        <result column="description" property="description"/>
        <result column="address_id" property="addressId"/>
        <result column="service_radius" property="serviceRadius"/>
        <result column="price" property="price"/>
        <result column="price_unit" property="priceUnit"/>
        <result column="available_time" property="availableTime"/>
        <result column="pet_types" property="petTypes"/>
        <result column="status" property="status"/>
        <result column="view_count" property="viewCount"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, user_id, service_type_id, title, description, address_id, service_radius, price, price_unit, available_time, pet_types, status, view_count, create_time, update_time
    </sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM service_publish WHERE id = #{id}
    </select>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM service_publish WHERE user_id = #{userId}
    </select>

    <select id="selectByServiceType" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM service_publish WHERE service_type_id = #{typeId}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM service_publish
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO service_publish (user_id, service_type_id, title, description, address_id, service_radius, price, price_unit, available_time, pet_types, status, view_count, create_time, update_time)
        VALUES (#{userId}, #{serviceTypeId}, #{title}, #{description}, #{addressId}, #{serviceRadius}, #{price}, #{priceUnit}, #{availableTime}, #{petTypes}, #{status}, #{viewCount}, NOW(), NOW())
    </insert>

    <update id="update">
        UPDATE service_publish
        <set>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="serviceTypeId != null">service_type_id = #{serviceTypeId},</if>
            <if test="title != null">title = #{title},</if>
            <if test="description != null">description = #{description},</if>
            <if test="addressId != null">address_id = #{addressId},</if>
            <if test="serviceRadius != null">service_radius = #{serviceRadius},</if>
            <if test="price != null">price = #{price},</if>
            <if test="priceUnit != null">price_unit = #{priceUnit},</if>
            <if test="availableTime != null">available_time = #{availableTime},</if>
            <if test="petTypes != null">pet_types = #{petTypes},</if>
            <if test="status != null">status = #{status},</if>
            <if test="viewCount != null">view_count = #{viewCount},</if>
            update_time = NOW()
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM service_publish WHERE id = #{id}
    </delete>
</mapper>
