<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.learnclaudedemo.mapper.PetMapper">
    <resultMap id="BaseResultMap" type="com.example.learnclaudedemo.entity.Pet">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="pet_name" property="petName"/>
        <result column="pet_type" property="petType"/>
        <result column="breed" property="breed"/>
        <result column="gender" property="gender"/>
        <result column="birth_date" property="birthDate"/>
        <result column="weight" property="weight"/>
        <result column="avatar" property="avatar"/>
        <result column="personality" property="personality"/>
        <result column="health_status" property="healthStatus"/>
        <result column="sterilized" property="sterilized"/>
        <result column="vaccinated" property="vaccinated"/>
        <result column="description" property="description"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, user_id, pet_name, pet_type, breed, gender, birth_date, weight, avatar, personality, health_status, sterilized, vaccinated, description, status, create_time, update_time
    </sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM pet WHERE id = #{id}
    </select>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM pet WHERE user_id = #{userId}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM pet
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO pet (user_id, pet_name, pet_type, breed, gender, birth_date, weight, avatar, personality, health_status, sterilized, vaccinated, description, status, create_time, update_time)
        VALUES (#{userId}, #{petName}, #{petType}, #{breed}, #{gender}, #{birthDate}, #{weight}, #{avatar}, #{personality}, #{healthStatus}, #{sterilized}, #{vaccinated}, #{description}, #{status}, NOW(), NOW())
    </insert>

    <update id="update">
        UPDATE pet
        <set>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="petName != null">pet_name = #{petName},</if>
            <if test="petType != null">pet_type = #{petType},</if>
            <if test="breed != null">breed = #{breed},</if>
            <if test="gender != null">gender = #{gender},</if>
            <if test="birthDate != null">birth_date = #{birthDate},</if>
            <if test="weight != null">weight = #{weight},</if>
            <if test="avatar != null">avatar = #{avatar},</if>
            <if test="personality != null">personality = #{personality},</if>
            <if test="healthStatus != null">health_status = #{healthStatus},</if>
            <if test="sterilized != null">sterilized = #{sterilized},</if>
            <if test="vaccinated != null">vaccinated = #{vaccinated},</if>
            <if test="description != null">description = #{description},</if>
            <if test="status != null">status = #{status},</if>
            update_time = NOW()
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM pet WHERE id = #{id}
    </delete>
</mapper>
