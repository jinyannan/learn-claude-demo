<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.learnclaudedemo.mapper.HelloMapper">
    <resultMap id="BaseResultMap" type="com.example.learnclaudedemo.entity.Hello">
        <id column="ID" property="id"/>
        <result column="CODE" property="code"/>
        <result column="NAME" property="name"/>
    </resultMap>

    <sql id="Base_Column_List">
        ID, CODE, NAME
    </sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM hello WHERE ID = #{id}
    </select>

    <insert id="insert">
        INSERT INTO hello (ID, CODE, NAME)
        VALUES (#{id}, #{code}, #{name})
    </insert>

    <update id="update">
        UPDATE hello
        <set>
            <if test="code != null">CODE = #{code},</if>
            <if test="name != null">NAME = #{name},</if>
        </set>
        WHERE ID = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM hello WHERE ID = #{id}
    </delete>
</mapper>
