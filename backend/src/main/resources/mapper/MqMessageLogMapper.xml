<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.learnclaudedemo.mapper.MqMessageLogMapper">
    <resultMap id="BaseResultMap" type="com.example.learnclaudedemo.entity.MqMessageLog">
        <id column="id" jdbcType="BIGINT" property="id" />
        <result column="message_content" jdbcType="VARCHAR" property="messageContent" />
        <result column="channel" jdbcType="VARCHAR" property="channel" />
        <result column="create_time" jdbcType="TIMESTAMP" property="createTime" />
    </resultMap>

    <insert id="insert" parameterType="com.example.learnclaudedemo.entity.MqMessageLog" useGeneratedKeys="true" keyProperty="id">
        insert into mq_message_log (message_content, channel, create_time)
        values (#{messageContent,jdbcType=VARCHAR}, #{channel,jdbcType=VARCHAR}, #{createTime,jdbcType=TIMESTAMP})
    </insert>
</mapper>
