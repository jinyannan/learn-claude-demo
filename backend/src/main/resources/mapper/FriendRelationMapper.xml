<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.learnclaudedemo.mapper.FriendRelationMapper">
    <resultMap id="BaseResultMap" type="com.example.learnclaudedemo.entity.FriendRelation">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="friend_id" property="friendId"/>
        <result column="remark" property="remark"/>
        <result column="is_blacklist" property="isBlacklist"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, user_id, friend_id, remark, is_blacklist, create_time
    </sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM friend_relation WHERE id = #{id}
    </select>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM friend_relation WHERE user_id = #{userId}
    </select>

    <select id="selectByUserAndFriend" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM friend_relation WHERE user_id = #{userId} AND friend_id = #{friendId}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO friend_relation (user_id, friend_id, remark, is_blacklist, create_time)
        VALUES (#{userId}, #{friendId}, #{remark}, #{isBlacklist}, NOW())
    </insert>

    <update id="update">
        UPDATE friend_relation
        <set>
            <if test="remark != null">remark = #{remark},</if>
            <if test="isBlacklist != null">is_blacklist = #{isBlacklist},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM friend_relation WHERE id = #{id}
    </delete>
</mapper>
